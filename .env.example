# Application
APP_NAME=Health1ERP
DEBUG=false
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8100

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/health1erp

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=change-this-to-a-very-long-random-string-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4
AI_ENABLED=true
CDSS_CONFIDENCE_THRESHOLD=0.7

# Storage
STORAGE_BACKEND=local
S3_BUCKET=
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
LOCAL_STORAGE_PATH=./uploads

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@health1erp.com

# SMS (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# FHIR/HL7
FHIR_SERVER_URL=
HL7_ENABLED=false

# i18n
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,hi,ar,es,fr,zh

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
