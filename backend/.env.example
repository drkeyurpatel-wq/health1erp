# =============================================================================
# Health1ERP Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# Generate keys with: python backend/scripts/generate_keys.py
# =============================================================================

# -- Application --------------------------------------------------------------
APP_NAME=Health1ERP
APP_VERSION=1.0.0
APP_ENV=dev                          # dev | staging | prod
DEBUG=false
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://localhost:8100"]
RATE_LIMIT_PER_MINUTE=60

# -- Database -----------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/health1erp
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# -- Redis --------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -- JWT / Auth ---------------------------------------------------------------
# IMPORTANT: Replace with a strong random key (min 32 chars).
SECRET_KEY=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -- Field-Level Encryption ---------------------------------------------------
# Used for encrypting sensitive patient data at rest.
# For key rotation, provide comma-separated keys (newest first).
FIELD_ENCRYPTION_KEY=
# FIELD_ENCRYPTION_KEYS=newest-key,previous-key,oldest-key

# -- AI / ML ------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4
AI_ENABLED=true
CDSS_CONFIDENCE_THRESHOLD=0.7

# -- Storage ------------------------------------------------------------------
STORAGE_BACKEND=local                # local | s3
S3_BUCKET=
S3_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
LOCAL_STORAGE_PATH=./uploads

# -- Email (SMTP) -------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@health1erp.com

# -- SMS (Twilio) -------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# -- Payment ------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# -- FHIR / HL7 ---------------------------------------------------------------
FHIR_SERVER_URL=
HL7_ENABLED=false

# -- Internationalization -----------------------------------------------------
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=["en","hi","ar","es","fr","zh"]

# -- Celery -------------------------------------------------------------------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
